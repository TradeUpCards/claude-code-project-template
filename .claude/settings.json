{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "teammateMode": "in-process",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push * --force-with-lease*)",
      "Bash(git push * --delete *)",
      "Bash(git push origin :*)",
      "Bash(git push * origin :*)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git reset *)",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(pip install *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(gh repo create *)",
      "Bash(glab repo create *)"
    ],
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git remote *)",
      "Bash(pytest *)",
      "Bash(python -m *)",
      "Bash(python -c *)",
      "Bash(npm test *)",
      "Bash(npm run test *)",
      "Bash(npm run lint *)"
    ]
  }
}
